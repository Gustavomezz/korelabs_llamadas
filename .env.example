# OpenAI Realtime
OPENAI_API_KEY=
OPENAI_REALTIME_MODEL=gpt-realtime

# Twilio
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=

# Postgres del Dashboard (resuelve número Twilio -> tenant + database_url cifrada)
DASHBOARD_DATABASE_URL=postgresql://user:pass@host:port/dbname

# Llave Fernet usada por el dashboard para cifrar database_urls de tenants
TENANT_DB_ENCRYPTION_KEY=

# URL pública del servicio (Railway). Usada para construir TwiML <Stream url="wss://...">
PUBLIC_BASE_URL=

# Puerto local (en Railway lo inyecta la plataforma)
PORT=8000

# Token para endpoints /admin/*
ADMIN_TOKEN=

# Google Calendar (mismas credenciales OAuth que el bot de WhatsApp del tenant).
# Solo se usan para refrescar tokens; el OAuth inicial ya lo hizo el bot WA y
# los tokens viven en la tabla google_tokens de la BD del tenant.
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
CALENDAR_TIMEZONE=America/Mexico_City
