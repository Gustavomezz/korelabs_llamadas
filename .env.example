# Proveedor de voz: 'openai' o 'grok'
VOICE_PROVIDER=openai

# OpenAI Realtime (si VOICE_PROVIDER=openai)
OPENAI_API_KEY=
# gpt-realtime-2: modelo top de OpenAI (GPT-5-class reasoning, mejor para
# objeciones complejas, naturalidad, instruction-following). Optimizado con
# todo abajo. Si necesitas latencia mínima absoluta y aceptas menos
# razonamiento, cambiar a 'gpt-realtime-mini' (~110ms más rápido).
OPENAI_REALTIME_MODEL=gpt-realtime-2
# minimal | low | medium | high | xhigh. minimal = latencia mínima,
# suficiente para calificación + agendamiento.
OPENAI_REASONING_EFFORT=minimal
# Limita largo de respuesta. 400 = 30-40s de voz cómoda. Bajar para más
# concisas (= próximo turno empieza antes), subir para respuestas largas.
OPENAI_MAX_OUTPUT_TOKENS=400

# Grok Voice Think Fast (si VOICE_PROVIDER=grok)
# Saca tu key en https://console.x.ai
XAI_API_KEY=
XAI_REALTIME_MODEL=grok-voice-think-fast-1.0
# Voces Grok: eve | ara | rex | sal | leo. ara = femenina cálida (recomendada)
GROK_VOICE=ara
# minimal (~450ms más rápido que low) | low | medium | high | xhigh
OPENAI_REASONING_EFFORT=minimal
# server_vad (rápido, configurable por ms) o semantic_vad (modelo NLU,
# pero timeout mínimo ~1-2s). Para baja latencia: server_vad agresivo.
REALTIME_VAD_TYPE=server_vad
# Solo para semantic_vad: low | medium | high
REALTIME_VAD_EAGERNESS=high
# Solo para server_vad: threshold (0-1, alto = menos sensible al ruido),
# silence_duration_ms (driver principal de latencia turn-by-turn — bajar
# para respuesta más rápida, subir si el bot interrumpe pausas naturales),
# prefix_padding_ms (audio antes del speech start incluido en el buffer).
REALTIME_VAD_THRESHOLD=0.85
REALTIME_VAD_SILENCE_MS=300
REALTIME_VAD_PREFIX_MS=200
# ms a esperar tras empezar a hablar antes de respetar barge-in (anti-eco)
BARGE_IN_GUARD_MS=500
# Conexiones WebSocket pre-conectadas a OpenAI listas para asignar a una llamada.
# Cada una ahorra ~500 ms del cold start (TCP+TLS+handshake). 0 deshabilita.
REALTIME_WS_POOL_SIZE=2
# Prompt server-stored creado en el dashboard de OpenAI (formato pmpt_xxx).
# Si está set, se usa en lugar del voice_prompt inline. Reduce payload del
# session.update y maximiza el prompt caching en OpenAI. Crear en
# https://platform.openai.com/playground o equivalente.
OPENAI_PROMPT_ID=

# Twilio
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=

# Postgres del Dashboard (resuelve número Twilio -> tenant + database_url cifrada)
DASHBOARD_DATABASE_URL=postgresql://user:pass@host:port/dbname

# Llave Fernet usada por el dashboard para cifrar database_urls de tenants
TENANT_DB_ENCRYPTION_KEY=

# URL pública del servicio (Railway). Usada para construir TwiML <Stream url="wss://...">
PUBLIC_BASE_URL=

# Puerto local (en Railway lo inyecta la plataforma)
PORT=8000

# Token para endpoints /admin/*
ADMIN_TOKEN=

# Google Calendar (mismas credenciales OAuth que el bot de WhatsApp del tenant).
# Solo se usan para refrescar tokens; el OAuth inicial ya lo hizo el bot WA y
# los tokens viven en la tabla google_tokens de la BD del tenant.
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
CALENDAR_TIMEZONE=America/Mexico_City
